# Server
SERVER_PORT=8080
ENV=development
APP_NAME=go-auth-playground

# Log Level
LOG_LEVEL=debug # valid values: debug, info, warn, error, fatal, panic
LOG_FORMAT=text # valid values: text, json
LOG_PRETTY=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=auth_auth_playground
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_CONNECT_TIMEOUT=10s
DB_CONN_LIFETIME=1h
DB_CONN_IDLE_TIME=30m

# JWT
JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
